<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit your chat</title>
</head>
<body>
  <p>Edit your chat: <%= chat.id %></p>
   <p>This chat was sent by <b><%= chat.from %></b> to <b><%= chat.to%></b></p>

   <form method="post" action="/chats/<%= chat.id %>?_method=put">
    <textarea name="msg" id="" rows="5" cols="30"><%= chat.msg %></textarea><br>
    <button>Edit</button>
   </form>
</body>
</html>